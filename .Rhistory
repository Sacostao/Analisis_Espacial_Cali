group_by(cod_barrio) %>%
summarise(E_j = sum(empleados, na.rm = TRUE)) %>%
mutate(x_j = E_j / sum(E_j))
E_total <- sum(total_ciudad$E_j)
# Datos del sector 3611
data_3611 <- data_indices %>% filter(ciiu_4 == 3611)
sector_3611 <- data_3611 %>%
group_by(cod_barrio) %>%
summarise(e_ij = sum(empleados, na.rm = TRUE)) %>%
full_join(total_ciudad, by = "cod_barrio") %>%
mutate(e_ij = replace_na(e_ij, 0),
z_j = e_ij / sum(e_ij))
E_i <- sum(sector_3611$e_ij)
# Cálculo de Índices
# IHH: Herfindahl-Hirschman
s_i <- data_3611$empleados / E_i
IHH <- sum(s_i^2)
# EG: Ellison-Glaeser
sum_x2 <- sum(sector_3611$x_j^2)
G <- sum((sector_3611$z_j - sector_3611$x_j)^2)
EG_gamma <- (G - (1 - sum_x2) * IHH) / ((1 - sum_x2) * (1 - IHH))
# MS: Maurel-Sédillot
MS_gamma <- (((sum(sector_3611$z_j^2) - sum_x2) / (1 - sum_x2)) - IHH) / (1 - IHH)
# 5. Significancia Estadística de EG
# Según EG (1997) H0: concentración aleatoria
z_score <- EG_gamma / (sqrt(2) * IHH)
p_value <- 2 * (1 - pnorm(abs(z_score)))
# 6. Tabla Resumen de Resultados
resultados <- data.frame(
Indice = c("IHH", "EG Gamma", "MS", "Z-Score (EG)", "P-Value (EG)"),
Valor = c(round(IHH, 6), round(EG_gamma, 6), round(MS_gamma, 6), round(z_score, 4), round(p_value, 6))
)
print(resultados)
# CÁLCULO DE ÍNDICES DE CONCENTRACIÓN
data_indices <- data_raw %>%
rename(empleados = ue026a1_nu) %>%
mutate(empleados = as.numeric(empleados))
total_ciudad <- data_indices %>%
group_by(cod_barrio) %>%
summarise(E_j = sum(empleados, na.rm = TRUE)) %>%
mutate(x_j = E_j / sum(E_j))
E_total <- sum(total_ciudad$E_j)
data_3611 <- data_indices %>% filter(ciiu_4 == 3611)
sector_3611 <- data_3611 %>%
group_by(cod_barrio) %>%
summarise(e_ij = sum(empleados, na.rm = TRUE)) %>%
full_join(total_ciudad, by = "cod_barrio") %>%
mutate(e_ij = replace_na(e_ij, 0),
z_j = e_ij / sum(e_ij))
E_i <- sum(sector_3611$e_ij)
# 2. Cálculo de Índices
s_i <- data_3611$empleados / E_i
IHH <- sum(s_i^2)
sum_x2 <- sum(sector_3611$x_j^2)
G <- sum((sector_3611$z_j - sector_3611$x_j)^2)
# EG y MS
EG_gamma <- (G - (1 - sum_x2) * IHH) / ((1 - sum_x2) * (1 - IHH))
MS_gamma <- (((sum(sector_3611$z_j^2) - sum_x2) / (1 - sum_x2)) - IHH) / (1 - IHH)
# Isard (IQ)
sector_3611 <- sector_3611 %>% mutate(IQ_part = abs(z_j - x_j))
IQ <- 0.5 * sum(sector_3611$IQ_part, na.rm = TRUE)
# 3. Prueba de Significancia para EG
# Hipótesis Nula (H0): La concentración geográfica es igual a la esperada por azar (gamma = 0).
# Hipótesis Alternativa (H1): Existe concentración geográfica superior a la aleatoria (gamma > 0).
z_score <- EG_gamma / (sqrt(2) * IHH)
p_value <- 2 * (1 - pnorm(abs(z_score)))
# 4. Tabla de resultados finales
resultados <- data.frame(
Indice = c("IHH (Concentración)", "EG Gamma", "MS Gamma", "IQ (Isard)", "Z-Score (EG)", "P-Value (EG)"),
Valor = c(round(IHH, 6), round(EG_gamma, 6), round(MS_gamma, 6), round(IQ, 4), round(z_score, 4), round(p_value, 6))
)
print(resultados)
